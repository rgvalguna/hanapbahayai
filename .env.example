# ── App ─────────────────────────────────────────────────────────────────
APP_NAME="HanapBahay AI"
APP_ENV=local
APP_DEBUG=true
APP_KEY=                        # php artisan key:generate
APP_URL=http://localhost:8000
WEB_URL=http://localhost:3000
LOG_CHANNEL=stack
LOG_LEVEL=debug

# ── Database ─────────────────────────────────────────────────────────────
DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=hanapbahay
DB_USERNAME=hanapbahay
DB_PASSWORD=

# ── Redis ────────────────────────────────────────────────────────────────
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=
REDIS_PORT=6379
QUEUE_CONNECTION=redis
SESSION_DRIVER=cookie
SESSION_DOMAIN=localhost
SANCTUM_STATEFUL_DOMAINS=localhost:3000

# ── Horizon / Cache ───────────────────────────────────────────────────────
HORIZON_PREFIX=hanapbahay:
CACHE_DRIVER=redis

# ── Scout / OpenSearch ────────────────────────────────────────────────────
SCOUT_DRIVER=opensearch
OPENSEARCH_HOST=http://localhost:9200

# ── Anthropic / Claude ────────────────────────────────────────────────────
ANTHROPIC_API_KEY=
ANTHROPIC_DEFAULT_MODEL=claude-opus-4-7-20251101
ANTHROPIC_HAIKU_MODEL=claude-haiku-4-5-20251101
ANTHROPIC_SONNET_MODEL=claude-sonnet-4-6-20251101

# ── OAuth ─────────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=${APP_URL}/auth/google/callback
APPLE_CLIENT_ID=
APPLE_CLIENT_SECRET=

# ── AWS / Storage ─────────────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=ap-southeast-1
AWS_BUCKET=hanapbahay-media
FILESYSTEM_DISK=s3

# ── Cloudflare R2 ─────────────────────────────────────────────────────────
CLOUDFLARE_R2_ACCESS_KEY_ID=
CLOUDFLARE_R2_SECRET_ACCESS_KEY=
CLOUDFLARE_R2_BUCKET=
CLOUDFLARE_R2_ENDPOINT=

# ── Mail ──────────────────────────────────────────────────────────────────
MAIL_MAILER=smtp
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM_ADDRESS="noreply@hanapbahay.ph"
MAIL_FROM_NAME="${APP_NAME}"

# ── Payments / PayMongo ───────────────────────────────────────────────────
PAYMONGO_SECRET_KEY=
PAYMONGO_PUBLIC_KEY=
PAYMONGO_WEBHOOK_SECRET=

# ── KYC / Veriff ─────────────────────────────────────────────────────────
VERIFF_API_KEY=
VERIFF_SECRET=

# ── Feature Flags / Unleash ───────────────────────────────────────────────
UNLEASH_URL=
UNLEASH_CLIENT_SECRET=

# ── Google Maps ───────────────────────────────────────────────────────────
GOOGLE_MAPS_API_KEY=
NEXT_PUBLIC_MAPLIBRE_STYLE=

# ── Python Ingestion Service ──────────────────────────────────────────────
INGESTION_API_URL=http://localhost:3002
INGESTION_SECRET=
