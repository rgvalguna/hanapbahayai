APP_NAME="HanapBahay AI"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# ── Database ──────────────────────────────────────────────────────────────────
DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=hanapbahay
DB_USERNAME=hanapbahay
DB_PASSWORD=secret

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# ── Cache / Session / Queue ───────────────────────────────────────────────────
CACHE_STORE=redis
SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_DOMAIN=localhost
QUEUE_CONNECTION=redis
BROADCAST_CONNECTION=log

# ── Sanctum SPA Auth ─────────────────────────────────────────────────────────
# Comma-separated list of domains the SPA is served from
SANCTUM_STATEFUL_DOMAINS=localhost:3000,127.0.0.1:3000

# ── CORS ──────────────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000

# ── Mail ──────────────────────────────────────────────────────────────────────
MAIL_MAILER=smtp
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="noreply@hanapbahay.ph"
MAIL_FROM_NAME="${APP_NAME}"

# ── OpenSearch / Scout ────────────────────────────────────────────────────────
SCOUT_DRIVER=opensearch
OPENSEARCH_HOST=http://localhost:9200
OPENSEARCH_INDEX_PREFIX=hanapbahay_

# ── Claude AI (Anthropic) ─────────────────────────────────────────────────────
ANTHROPIC_API_KEY=
# Model routing: advisory uses opus, ingestion/fraud uses sonnet, classification uses haiku
ANTHROPIC_MODEL_ADVISORY=claude-opus-4-7
ANTHROPIC_MODEL_REVIEW=claude-sonnet-4-6
ANTHROPIC_MODEL_CLASSIFY=claude-haiku-4-5-20251001

# ── Google OAuth + Geocoding ──────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/api/v1/auth/google/callback
GOOGLE_MAPS_API_KEY=

# ── Apple OAuth ───────────────────────────────────────────────────────────────
APPLE_CLIENT_ID=
APPLE_CLIENT_SECRET=
APPLE_REDIRECT_URI=http://localhost:8000/api/v1/auth/apple/callback

# ── PayMongo (payments) ───────────────────────────────────────────────────────
PAYMONGO_PUBLIC_KEY=
PAYMONGO_SECRET_KEY=
PAYMONGO_WEBHOOK_SECRET=

# ── Veriff (broker KYC) ───────────────────────────────────────────────────────
VERIFF_API_KEY=
VERIFF_API_SECRET=

# ── SMS / OTP (Semaphore or Vonage) ───────────────────────────────────────────
SMS_PROVIDER=semaphore
SEMAPHORE_API_KEY=
SEMAPHORE_SENDER_NAME=HanapBahay

# ── Object Storage (S3 / Cloudflare R2) ──────────────────────────────────────
FILESYSTEM_DISK=s3
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=ap-southeast-1
AWS_BUCKET=hanapbahay-assets
AWS_ENDPOINT=                   # Set for R2: https://<accountid>.r2.cloudflarestorage.com
AWS_USE_PATH_STYLE_ENDPOINT=false

# ── Python Ingestion Service ──────────────────────────────────────────────────
INGESTION_SERVICE_URL=http://localhost:8001
INGESTION_SERVICE_SECRET=

# ── Horizon (queue dashboard) ────────────────────────────────────────────────
HORIZON_DARKMODE=true

# ── Feature Flags (Unleash) ───────────────────────────────────────────────────
UNLEASH_URL=
UNLEASH_API_TOKEN=
UNLEASH_APP_NAME=hanapbahay-api

# ── Sentry Error Tracking ─────────────────────────────────────────────────────
SENTRY_LARAVEL_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1
